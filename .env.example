# ============================================
# Crucix Intelligence Engine — Configuration
# ============================================
# Copy this file to .env and fill in your keys.
# Keys are optional — sources without keys degrade gracefully.
#
# IMPORTANT: Do NOT put comments on the same line as values.
# Docker env_file treats inline comments as part of the value.

# ═══════════════════════════════════════════
# SERVER CONFIGURATION
# ═══════════════════════════════════════════

# Dashboard server port (Railway sets this automatically)
PORT=3117

# Environment mode: development | production
NODE_ENV=development

# Auto-refresh interval (minutes)
REFRESH_INTERVAL_MINUTES=15

# Storage mode: memory (cloud/ephemeral) | file (local/persistent)
# Default: 'file' in development, 'memory' in production
STORAGE_MODE=

# ═══════════════════════════════════════════
# FEATURE FLAGS
# ═══════════════════════════════════════════
# Set to 'false' to disable specific features.
# All default to 'true' when not set.

# Enable intelligence sweep cycles
ENABLE_SWEEPS=true

# Enable Server-Sent Events (live updates)
ENABLE_SSE=true

# Enable Telegram bot integration
ENABLE_TELEGRAM=true

# Enable Discord bot integration
ENABLE_DISCORD=true

# ═══════════════════════════════════════════
# OSINT SOURCE API KEYS (all optional)
# ═══════════════════════════════════════════

# Federal Reserve Economic Data (free: fred.stlouisfed.org/docs/api)
FRED_API_KEY=
# NASA FIRMS fire data (free: firms.modaps.eosdis.nasa.gov/api)
FIRMS_MAP_KEY=
# Energy Information Administration (free: api.eia.gov/register)
EIA_API_KEY=
# Maritime AIS data (aisstream.io)
AISSTREAM_API_KEY=
# Armed Conflict Location & Event Data (acleddata.com/user/register)
ACLED_EMAIL=
# OAuth2 password grant (API keys deprecated Sept 2025)
ACLED_PASSWORD=

# ═══════════════════════════════════════════
# LLM LAYER (optional)
# ═══════════════════════════════════════════
# Enables AI-enhanced trade ideas and breaking news alerts.
# Provider options: anthropic | openai | gemini | codex

LLM_PROVIDER=
# Not needed for codex (uses ~/.codex/auth.json)
LLM_API_KEY=
# Optional model override. Each provider has a sensible default.
LLM_MODEL=

# ═══════════════════════════════════════════
# TELEGRAM ALERTS (optional)
# ═══════════════════════════════════════════
# Create a bot via @BotFather, get chat ID via @userinfobot

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ═══════════════════════════════════════════
# DISCORD ALERTS (optional)
# ═══════════════════════════════════════════

DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_GUILD_ID=
DISCORD_WEBHOOK_URL=

# ═══════════════════════════════════════════
# RAILWAY DEPLOYMENT NOTES
# ═══════════════════════════════════════════
# Railway automatically sets PORT. Do NOT set PORT on Railway.
# Set NODE_ENV=production on Railway.
# STORAGE_MODE defaults to 'memory' in production (ephemeral filesystem).
# All API keys and integrations are optional — the app runs without any.
