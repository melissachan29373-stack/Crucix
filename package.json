{
  "name": "crucix",
  "version": "3.0.0",
  "description": "Cloud-native intelligence engine — 27 OSINT sources, real-time dashboard, live alerts.",
  "type": "module",
  "scripts": {
    "start": "node src/server.mjs",
    "dev": "node --trace-warnings src/server.mjs",
    "start:web": "ENABLE_SWEEPS=false ENABLE_TELEGRAM=false ENABLE_DISCORD=false node src/server.mjs",
    "start:worker": "ENABLE_SSE=false node src/server.mjs",
    "sweep": "node apis/briefing.mjs",
    "brief": "node apis/briefing.mjs",
    "brief:save": "node apis/save-briefing.mjs",
    "diag": "node diag.mjs",
    "clean": "node scripts/clean.mjs",
    "fresh-start": "npm run clean && npm start"
  },
  "keywords": ["osint", "intelligence", "dashboard", "geopolitical", "railway"],
  "author": "Crucix",
  "license": "AGPL-3.0-only",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "dependencies": {
    "express": "^5.1.0"
  },
  "optionalDependencies": {
    "discord.js": "^14.25.0"
  }
}
